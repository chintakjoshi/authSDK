# -----------------------------------------------------------------------------
# Local Docker defaults for auth-service
# Docker Compose injects these settings into the app containers. Copy this file
# to `.env` at repository root when you want local overrides.
# -----------------------------------------------------------------------------

APP__ENVIRONMENT=development
APP__SERVICE=auth-service
APP__HOST=0.0.0.0
# Controls both the container bind port and the published host port.
APP__PORT=8000
APP__LOG_LEVEL=INFO
# Required in production to enable host-header enforcement.
# APP__ALLOWED_HOSTS=["auth.example.com","api.auth.example.com"]
# Optional: trust X-Forwarded-For only from these proxy CIDRs in production.
# APP__TRUSTED_PROXY_CIDRS=["10.0.0.0/8","192.168.0.0/16"]

# Local Postgres credentials for Docker Compose and Adminer
POSTGRES_PASSWORD=postgres

# Container-internal service URLs (used by auth-service container)
DATABASE__URL=postgresql+asyncpg://postgres:postgres@postgres:5432/auth_service
REDIS__URL=redis://redis:6379/0
ADMINER_PORT=8080

JWT__ALGORITHM=RS256
JWT__ACCESS_TOKEN_TTL_SECONDS=900
JWT__REFRESH_TOKEN_TTL_SECONDS=604800

# Optional for Docker compose flow:
# Leave these unset to let container startup generate ephemeral RSA keys.
# JWT__PRIVATE_KEY_PEM=
# JWT__PUBLIC_KEY_PEM=

OAUTH__GOOGLE_CLIENT_ID=local-google-client-id
OAUTH__GOOGLE_CLIENT_SECRET=local-google-client-secret
OAUTH__GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
OAUTH__REDIRECT_URI_ALLOWLIST=["http://localhost:8000/auth/oauth/google/callback"]
# Production must use HTTPS redirect URLs.

SAML__SP_ENTITY_ID=local-sp-entity
SAML__SP_ACS_URL=http://localhost:8000/auth/saml/callback
SAML__SP_X509_CERT=local-sp-cert
SAML__SP_PRIVATE_KEY=local-sp-private-key
SAML__IDP_ENTITY_ID=local-idp-entity
SAML__IDP_SSO_URL=https://idp.example.com/sso
SAML__IDP_X509_CERT=local-idp-cert
# Production must use HTTPS ACS and IdP SSO URLs.

RATE_LIMIT__DEFAULT_REQUESTS_PER_MINUTE=120
RATE_LIMIT__LOGIN_REQUESTS_PER_MINUTE=10
RATE_LIMIT__TOKEN_REQUESTS_PER_MINUTE=30

# Authentication policy controls
AUTH__REQUIRE_VERIFIED_EMAIL_FOR_PASSWORD_LOGIN=true

# Browser-session settings for same-origin web apps
# Local HTTP development uses non-prefixed cookie names on purpose. Browsers
# require __Host-* cookies to be Secure and Path=/, so those names are only
# appropriate once the app is served over real HTTPS.
BROWSER_SESSIONS__ENABLED=true
# Default is true. Set to false only if you need to temporarily force
# explicit X-Auth-Session-Transport negotiation again.
BROWSER_SESSIONS__INFER_COOKIE_TRANSPORT=true
BROWSER_SESSIONS__TRANSPORT_HEADER_NAME=X-Auth-Session-Transport
BROWSER_SESSIONS__ACCESS_COOKIE_NAME=auth_access
BROWSER_SESSIONS__REFRESH_COOKIE_NAME=auth_refresh
BROWSER_SESSIONS__CSRF_COOKIE_NAME=auth_csrf
BROWSER_SESSIONS__SAME_SITE=lax
# Set to true in staging and production when serving the app over HTTPS.
BROWSER_SESSIONS__SECURE_ONLY=false
# Leave unset for host-only cookies. Set only for intentional broader cookie scope.
# BROWSER_SESSIONS__COOKIE_DOMAIN=
# Recommended when browser apps proxy authSDK under /_auth.
BROWSER_SESSIONS__ACCESS_COOKIE_PATH=/
BROWSER_SESSIONS__REFRESH_COOKIE_PATH=/_auth
BROWSER_SESSIONS__CSRF_COOKIE_PATH=/
BROWSER_SESSIONS__CSRF_HEADER_NAME=X-CSRF-Token
# HTTPS production example:
# BROWSER_SESSIONS__ACCESS_COOKIE_NAME=__Host-auth_access
# BROWSER_SESSIONS__REFRESH_COOKIE_NAME=__Secure-auth_refresh
# BROWSER_SESSIONS__CSRF_COOKIE_NAME=__Host-auth_csrf
# BROWSER_SESSIONS__SECURE_ONLY=true

# Optional scheduled retention purge controls
RETENTION__ENABLE_RETENTION_PURGE=false
RETENTION__AUDIT_LOG_RETENTION_DAYS=90
RETENTION__SESSION_LOG_RETENTION_DAYS=30
RETENTION__PURGE_CRON=0 3 * * *

# Email verification and OTP settings (Mailhog)
EMAIL__MAILHOG_HOST=mailhog
EMAIL__MAILHOG_PORT=1025
EMAIL__EMAIL_FROM=auth@localhost
EMAIL__PUBLIC_BASE_URL=http://localhost:8000
EMAIL__EMAIL_VERIFY_TTL_SECONDS=86400
EMAIL__PASSWORD_RESET_TTL_SECONDS=3600
EMAIL__OTP_CODE_LENGTH=6
EMAIL__OTP_TTL_SECONDS=600
EMAIL__OTP_MAX_ATTEMPTS=5
EMAIL__ACTION_TOKEN_TTL_SECONDS=300

# Signing key rotation controls
SIGNING_KEYS__ROTATION_OVERLAP_SECONDS=900
# Production must set both encryption keys and must not set ADMIN_API_KEY.
SIGNING_KEYS__ENCRYPTION_KEY=local-dev-signing-keys-encryption-key
WEBHOOK__QUEUE_NAME=webhooks
WEBHOOK__REQUEST_TIMEOUT_SECONDS=10
WEBHOOK__RESPONSE_BODY_MAX_CHARS=1000
WEBHOOK__WORKER_TTL_SECONDS=120
WEBHOOK__REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
WEBHOOK__SECRET_ENCRYPTION_KEY=local-dev-webhook-secret-encryption-key
# Optional local bootstrap access for `/admin/*` in development only.
# ADMIN_API_KEY=local-admin-bootstrap-key
